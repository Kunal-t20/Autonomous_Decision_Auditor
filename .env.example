# Copy to .env and fill values. Do not commit .env.

# Required: PostgreSQL (e.g. Neon)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# LLM
groq_api_key=
hf_api_key=

# Tests: set TEST_MODE=true to avoid real Groq calls
TEST_MODE=false

# Redis (optional): LLM response cache + optional rate limiting
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
LLM_CACHE_TTL_SECONDS=86400
LLM_CACHE_KEY_PREFIX=llm:v1:

# Rate limit POST /audit (requires REDIS_ENABLED=true)
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60
